import {
  Routes,
  Route
} from "react-router-dom";

import Home from "./pages/Home";
import Login from "./pages/Login";
import Register from "./pages/Register";
import BlogForm from "./pages/BlogForm";

function App() {

  return (

    <Routes>

      <Route
        path="/"
        element={<Home />}
      />

      <Route
        path="/login"
        element={<Login />}
      />

      <Route
        path="/register"
        element={<Register />}
      />

      <Route
        path="/create"
        element={<BlogForm />}
      />

      <Route
        path="/edit/:id"
        element={<BlogForm />}
      />

    </Routes>

  );
}

export default App;


