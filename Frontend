import { useState } from "react";
import API from "../api";

function Register() {

  const [form,setForm] =
    useState({

      username:"",
      email:"",
      password:""

    });

  const submit = async () => {

    await API.post(
      "register/",
      form
    );

    alert("Registered");
  };

  return (

    <div>

      <h2>
        Register
      </h2>

      <input
        placeholder="Username"
        onChange={(e)=>

          setForm({
            ...form,
            username:e.target.value
          })

        }
      />

      <br /><br />

      <input
        placeholder="Email"
        onChange={(e)=>

          setForm({
            ...form,
            email:e.target.value
          })

        }
      />

      <br /><br />

      <input
        type="password"
        placeholder="Password"
        onChange={(e)=>

          setForm({
            ...form,
            password:e.target.value
          })

        }
      />

      <br /><br />

      <button
        onClick={submit}
      >
        Register
      </button>

