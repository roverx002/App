import { Link } from "react-router-dom";

function Navbar() {

  const token =
    localStorage.getItem("token");

  const logout = () => {

    localStorage.removeItem("token");

    window.location.href = "/";
  };

  return (

    <div>

      <Link to="/">
        Home
      </Link>

      {" | "}

      {!token ? (

        <>
          <Link to="/login">
            Login
          </Link>

          {" | "}

          <Link to="/register">
            Register
          </Link>
        </>

      ) : (

        <>
          <Link to="/create">
            New Blog
          </Link>

          {" | "}

          <button
            onClick={logout}
          >
            Logout
          </button>
        </>

      )}

      <hr />

    </div>

  );
}

export default Navbar;


